# ── Auth ──────────────────────────────────────────────────────────────
# 32+ random characters; signs every session cookie. Rotating it signs everyone out.
AUTH_SECRET=

# ── Hosts (no protocol) ───────────────────────────────────────────────
# Unified mode: ONE hostname serving everything — the sign-in page at /,
# the student portal at /student/<id>, staff at /staff/<id>, management at
# /admin. Production: library.thelangschool.org. Local dev: localhost:4173.
UNIFIED_HOST=localhost:4173
# Legacy dual-host mode (still works alongside unified during a transition):
# the two site hostnames (vercel.app aliases or school subdomains).
# Local dev:  student.localhost:4173 / staff.localhost:4173
STUDENT_HOST=student.localhost:4173
STAFF_HOST=staff.localhost:4173

# ── Supabase (server-side only; never exposed to the browser) ─────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Email (Gmail SMTP — no DNS needed) ────────────────────────────────
# Sends AS this mailbox through smtp.gmail.com. On the account: enable
# 2-Step Verification, then create an App password (myaccount.google.com/apppasswords).
GMAIL_USER=library@thelangschool.org
GMAIL_APP_PASSWORD=
# Optional: reroute ALL outgoing mail to one inbox (testing / dry runs):
EMAIL_OVERRIDE_TO=

# ── Cron ──────────────────────────────────────────────────────────────
# Bearer token protecting /api/cron/daily
CRON_SECRET=

# ── Push notifications (app updates) ──────────────────────────────────
# Generate once: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
